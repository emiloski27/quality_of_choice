with premiums as
	(
	select DISTINCT 
        rfq_id, 
        q.unified_profile_id,
        q.primary_detail,
        p.super_segment,
        p.us_new_trade_industry,
        q.panel_rank,
        panel_quotes,
        quote_id, 
        created_at,
        gross_premium_ex_ipt,
        quote_outcome,
	    max(gross_premium_ex_ipt) OVER (PARTITION BY rfq_id) AS max_premium,
	    min(gross_premium_ex_ipt) OVER (PARTITION BY rfq_id) AS min_premium,
        100*(max_premium - min_premium)/min_premium as relatve_diff,
        max_premium - min_premium as diff
	from analytics_hub.core.quotes q
	JOIN analytics_hub.analytics_hub.etl_clean_global_primary_detail_segmentation p 
		ON upper(q.primary_detail) = upper(p.primary_detail) and q.business_unit = p.business_unit
	where quoting_status = 'quoted'
	and q.business_unit = 'simplybusiness_us'
    --and q.distribution_channel = 'simplybusiness_us'
	and lifecycle = 'New Business'
	and created_at >= '2023-01-01'
	and sorted_requested_covers = 'General Liability'
	and panel_quotes > 1
    and channel = 'web'
    order by 1
	),
averages AS 
	(
	SELECT 
        p.primary_detail, 
        p.super_segment,
        p.us_new_trade_industry,
        count(DISTINCT p.rfq_id) as rfqs_quoted,
        --avg(relatve_diff) as avg_relative_tradelevel,
        --avg(diff) as avg_diff,
        --stddev(relatve_diff) as std_relative
		FROM premiums p
		GROUP BY 1, 2, 3
	),
buckets as(
	SELECT DISTINCT 
    p.rfq_id, 
    p.quote_id,
    p.panel_quotes,
    p.unified_profile_id,
    gross_premium_ex_ipt, 
    p.primary_detail,
    p.created_at,
    p.super_segment,
    p.max_premium,
    p.min_premium, 
    p.panel_rank,
    p.quote_outcome, 
    relatve_diff, 
    p.diff,
    p.us_new_trade_industry,
    annual_revenue,
    --years trading
    CASE
      WHEN (UPPER((rfq_details.full_payload:years_trading::string)) = '0') THEN '0'
      WHEN (UPPER((rfq_details.full_payload:years_trading::string)) = '1') THEN '1'
      WHEN (UPPER((rfq_details.full_payload:years_trading::string)) = '2') THEN '2'
      WHEN (UPPER((rfq_details.full_payload:years_trading::string)) = '3') THEN '3'
      WHEN (UPPER((rfq_details.full_payload:years_trading::string)) = '4') THEN '4'
      WHEN ((((rfq_details.full_payload:years_trading::string)) IS NULL)) THEN 'Null'
        ELSE '5+' END AS years_trading_bucket,
    --employee count
    CASE
        WHEN (UPPER((rfq_details.full_payload:employee_count::string)) = '0') THEN '0'
        WHEN (UPPER((rfq_details.full_payload:employee_count::string)) = '1') THEN '1'
        WHEN (UPPER((rfq_details.full_payload:employee_count::string)) = '2') THEN '2'
        WHEN (UPPER((rfq_details.full_payload:employee_count::string)) = '3') THEN '3'
        WHEN (UPPER((rfq_details.full_payload:employee_count::string)) = '4') THEN '4'
        WHEN ((((rfq_details.full_payload:employee_count::string)) IS NULL)) THEN 'Null'
            ELSE '5+' END as employee_count,
    --business_type
    core_rfqs.business_type,
    --employee_payroll_bucket 
    CASE
        WHEN core_rfqs.employee_payroll  < 40000 THEN 'Below 40,000'
        WHEN core_rfqs.employee_payroll  >= 40000 AND core_rfqs.employee_payroll  < 100000 THEN '40,000 to 99,999'
        WHEN core_rfqs.employee_payroll  >= 100000 THEN '100,000 or Above'
            ELSE 'Undefined'END AS employee_payroll_bucket,
    --revenue
     CASE
        WHEN core_rfqs.annual_revenue  < 10000 THEN 'Below 10,000'
        WHEN core_rfqs.annual_revenue  >= 10000 AND core_rfqs.annual_revenue  < 40000 THEN '10,000 to 39,999'
        WHEN core_rfqs.annual_revenue  >= 40000 AND core_rfqs.annual_revenue  < 100000 THEN '40,000 to 99,999'
        WHEN core_rfqs.annual_revenue  >= 100000 AND core_rfqs.annual_revenue  < 500000 THEN '100,000 to 499,999'
        WHEN core_rfqs.annual_revenue  >= 500000 THEN '500,000 or Above'
            ELSE 'Undefined' END AS annual_revenue_bucket,
    --buckets
    case 
        when relatve_diff < 60.0 then 'small' 
        when relatve_diff between 60.0 and 120.0 then 'medium'
        when relatve_diff > 120.0 then 'large'
            else 'idk man' end as static_choice
	FROM premiums p 
	JOIN averages a ON a.primary_detail = p.primary_detail
    JOIN analytics_hub.core.rfq_details 
        on rfq_details.rfq_id = p.rfq_id
    JOIN analytics_hub.core.rfqs core_rfqs
        on core_rfqs.rfq_id = p.rfq_id
	)
select  *
from buckets
where super_segment in ('Professionals', 'Lifestyle', 'Tradespeople') 
order by 1, 2;

select 
    super_segment,
   --static_choice,
    avg(relatve_diff) as avg_relative,
    avg(diff) as avg_diff_number,
    median(min_premium) as median_min,
    count(distinct rfq_id) as quotes,
    count(DISTINCT CASE WHEN quote_outcome = 'Converted to sale' THEN rfq_id ELSE NULL END) AS sales,
    (100*sales)/(quotes) as hitrate,
    avg(CASE WHEN quote_outcome = 'Converted to sale' THEN panel_rank ELSE NULL END) as avg_panel_rank,
    avg(CASE WHEN quote_outcome = 'Converted to sale' THEN gross_premium_ex_ipt ELSE NULL END) as avg_bound
from {{base}}
where super_segment in ('Professionals', 'Lifestyle', 'Tradespeople')
and created_at >= '2023-01-01'
    and static_choice <> 'oops'
    group by 1--,  2  
    order by 1 , 2
